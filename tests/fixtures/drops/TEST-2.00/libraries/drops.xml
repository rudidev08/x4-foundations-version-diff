<?xml version="1.0" encoding="utf-8"?>
<droplists>

  <!-- ammo sub-source:
       - basket_ammo_01: modified (weight/max attr changes; one select added,
         one removed)
       - basket_ammo_new: added in TEST-2 (core) -->
  <ammo id="basket_ammo_01" selection="random">
    <select weight="9" macro="missile_cluster_light_mk1_macro" min="2" max="4"/>
    <select weight="12" macro="missile_dumbfire_light_mk1_macro" min="3" max="6"/>
    <select weight="8" macro="missile_dumbfire_light_mk2_macro" min="2" max="5"/>
    <select weight="7" macro="missile_heatseeker_light_mk1_macro" min="2" max="4"/>
  </ammo>

  <ammo id="basket_ammo_new" selection="random">
    <select weight="4" macro="missile_smart_light_mk1_macro" min="1" max="2"/>
  </ammo>

  <!-- wares sub-source:
       - basket_wares_common_01: multiset-modified (see details below)
       - basket_wares_unchanged: identical across versions -->
  <wares id="basket_wares_common_01" selection="random">
    <!-- (weight=7, [(inv_algaescrubber, 1)]) shared twice in TEST-1.
         TEST-2 keeps ONE identical; the other shifts to amount=5. -->
    <select weight="7">
      <ware ware="inv_algaescrubber" amount="1"/>
    </select>
    <select weight="7">
      <ware ware="inv_algaescrubber" amount="5"/>
    </select>
    <!-- (weight=10, [(inv_carbonfilter, 2)]) kept unchanged (pair). -->
    <select weight="10">
      <ware ware="inv_carbonfilter" amount="2"/>
    </select>
    <!-- (weight=5, microgimble) removed; new (weight=8, newware) added. -->
    <select weight="8">
      <ware ware="inv_newware" amount="2"/>
    </select>
  </wares>

  <wares id="basket_wares_unchanged" selection="random">
    <select weight="3">
      <ware ware="inv_bandages" amount="1"/>
    </select>
  </wares>

  <!-- droplist sub-source:
       - drops_crystal_s_01: multiset-modified
       - drops_new_mission: added in TEST-2 (core) -->
  <droplist id="drops_crystal_s_01">
    <drop macro="collectable_crystal_s_01_macro" min="1" max="1" chance="20">
      <ware ware="inv_unstablecrystal" amount="1"/>
    </drop>
    <drop macro="collectable_crystal_s_01_macro" min="1" max="1" chance="30">
      <ware ware="inv_unstablecrystal" amount="1"/>
    </drop>
    <drop macro="collectable_crystal_s_01_macro" min="5" max="10">
      <ware ware="inv_crystal_01" amount="3" chance="100"/>
    </drop>
  </droplist>

  <droplist id="drops_new_mission">
    <drop macro="sm_gen_ammo_01_macro">
      <ware ware="inv_mission_reward" amount="2"/>
    </drop>
  </droplist>

</droplists>
