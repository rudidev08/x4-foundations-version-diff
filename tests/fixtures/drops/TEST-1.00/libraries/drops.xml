<?xml version="1.0" encoding="utf-8"?>
<droplists>

  <!-- ammo sub-source:
       - basket_ammo_01: modified
       - basket_ammo_removed: only in TEST-1 (removed) -->
  <ammo id="basket_ammo_01" selection="random">
    <select weight="7" macro="missile_cluster_light_mk1_macro" min="2" max="4"/>
    <select weight="12" macro="missile_dumbfire_light_mk1_macro" min="3" max="6"/>
    <select weight="8" macro="missile_dumbfire_light_mk2_macro" min="2" max="4"/>
    <select weight="5" macro="missile_emp_mk1_macro" min="1" max="2"/>
  </ammo>

  <ammo id="basket_ammo_removed" selection="random">
    <select weight="1" macro="missile_torpedo_heavy_mk1_macro" min="1" max="2"/>
  </ammo>

  <!-- wares sub-source:
       - basket_wares_common_01: modified with multiset diff
       - basket_wares_unchanged: identical across versions (emits nothing) -->
  <wares id="basket_wares_common_01" selection="random">
    <!-- Two selects share sig (weight=7, [(inv_algaescrubber, 1)]).
         In TEST-2 one keeps identical; the other shifts to amount=5.
         Multiset pairs one survivor + emits one add/remove for the shift. -->
    <select weight="7">
      <ware ware="inv_algaescrubber" amount="1"/>
    </select>
    <select weight="7">
      <ware ware="inv_algaescrubber" amount="1"/>
    </select>
    <select weight="10">
      <ware ware="inv_carbonfilter" amount="2"/>
    </select>
    <select weight="5">
      <ware ware="inv_microgimble" amount="3"/>
    </select>
  </wares>

  <wares id="basket_wares_unchanged" selection="random">
    <select weight="3">
      <ware ware="inv_bandages" amount="1"/>
    </select>
  </wares>

  <!-- droplist sub-source:
       - drops_crystal_s_01: modified with multiset diff
       - drops_tutorial: only in TEST-1 (removed) -->
  <droplist id="drops_crystal_s_01">
    <!-- Two drops share attr-signature (macro, min=1, max=1, chance=20);
         one keeps identical, the other's @chance bumps to 30 in TEST-2.
         Tests drop-attr multiset. -->
    <drop macro="collectable_crystal_s_01_macro" min="1" max="1" chance="20">
      <ware ware="inv_unstablecrystal" amount="1"/>
    </drop>
    <drop macro="collectable_crystal_s_01_macro" min="1" max="1" chance="20">
      <ware ware="inv_unstablecrystal" amount="1"/>
    </drop>
    <!-- Drop with direct <ware> children to exercise the nested-payload
         branch of the signature. In TEST-2 @amount bumps 2→3. -->
    <drop macro="collectable_crystal_s_01_macro" min="5" max="10">
      <ware ware="inv_crystal_01" amount="2" chance="100"/>
    </drop>
  </droplist>

  <droplist id="drops_tutorial">
    <drop macro="sm_gen_ammo_01_macro">
      <ware ware="inv_tutorial_ammo" amount="1"/>
    </drop>
  </droplist>

</droplists>
