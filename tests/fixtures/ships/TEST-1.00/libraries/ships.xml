<?xml version="1.0" encoding="utf-8"?>
<ships xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="libraries.xsd">
  <ship id="argon_fighter_m" group="arg_fighter_m">
    <category tags="[fighter, mission]" faction="[argon]" size="ship_m"/>
    <pilot>
      <select faction="argon" tags="fighterpilot"/>
    </pilot>
    <drop ref="ship_medium_military"/>
    <people ref="argon_fighter_crew"/>
  </ship>
  <ship id="argon_transport_m" group="arg_transport_m">
    <category tags="[trader, container, mission]" faction="[argon, hatikvah]" size="ship_m"/>
    <pilot>
      <select faction="argon" tags="traderpilot"/>
    </pilot>
    <basket basket="all_container"/>
    <drop ref="ship_medium_civilian"/>
    <people ref="argon_freighter_crew"/>
  </ship>
  <ship id="argon_fighter_s" group="arg_fighter_s">
    <category tags="[fighter, mission]" faction="[argon]" size="ship_s"/>
    <pilot>
      <select faction="argon" tags="fighterpilot"/>
    </pilot>
    <drop ref="ship_small_military"/>
    <people ref="argon_fighter_crew"/>
  </ship>
</ships>
