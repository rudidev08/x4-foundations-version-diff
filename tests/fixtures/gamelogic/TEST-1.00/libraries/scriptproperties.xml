<?xml version="1.0" encoding="utf-8"?>
<scriptproperties>
  <datatype name="component">
    <property name="exists" result="true iff present" type="boolean" />
    <property name="deprecated_prop" result="deprecated" type="string" />
  </datatype>
  <datatype name="object">
    <property name="isclass.{$class}" result="true iff of class" type="boolean">
      <param name="class" type="class" />
    </property>
  </datatype>
</scriptproperties>
