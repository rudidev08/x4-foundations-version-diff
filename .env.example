# X4 changelog pipeline config. Copy to .env and edit. .env is gitignored.
#
# Two scripts read this file:
#   scripts/release_notes_llm.py       — per-rule LLM summaries
#   scripts/aggregate_release_notes.py — merge summaries into release notes
#
# Both honor the same budget rules. Controls, in precedence order:
#
#   1. CLI --max-tokens N                (explicit override)
#   2. X4_LLM_MAX_TOKENS                 (global default for any model)
#   3. <ACTIVE_PROFILE>_CHUNK_KB × 256   (per-profile, auto-selected below)
#   4. Hard default 24000                (inside the scripts)
#
# CHUNK_KB is "kilobytes of characters" per LLM call (≈ 256 tokens per KB
# at the 4-chars/token rule of thumb). The tree-reduce aggregator never
# exceeds this — if inputs are too big it splits into batches and merges
# recursively, so smaller models just do more calls, not fewer details.
#
# Recommended CHUNK_KB per model context window (leaves ~25-30% headroom
# for output + reasoning traces):
#
#   8k context   (GPT-4 base, local 7B models)          CHUNK_KB=15
#   16k context  (GPT-3.5-turbo-16k, Llama 3 8B)        CHUNK_KB=30
#   32k context  (GPT-4-32k, Mixtral 8x7B)              CHUNK_KB=80
#   128k context (GPT-4-turbo, GPT-4o, Llama 3 70B)     CHUNK_KB=300
#   200k context (Claude 3 / 3.5 family)                CHUNK_KB=600
#   400k context (GPT-5.4 / o-series full)              CHUNK_KB=1000
#   1M+ context  (Gemini 1.5+)                          CHUNK_KB=2000
#
# Our own tests on real data suggest smaller values than the raw maximums.
# Many models lose detail in the output once a single call carries too much
# input, even when it technically fits. Treat CHUNK_KB as a quality knob,
# not a context-window cap.

# Path to the directory holding extracted X4 version subfolders
# (e.g. x4-data/9.00B5, x4-data/9.00B6). Relative paths resolve from
# the project root. CLI --game-data overrides this.
SOURCE_PATH_PREFIX=x4-data

# Optional global override. Leave blank to use the active profile's
# CHUNK_KB * 256. Set an integer (tokens) to force the same budget for
# every model.
# X4_LLM_MAX_TOKENS=24000

# ─── Models ─────────────────────────────────────────────────────────────
# Each model is three keys:
#   <KEY>_MODEL_NAME  — short display name (kebab-case). Used to look up
#                       the model and in output paths / filenames.
#   <KEY>_LLM_CMD     — full shell command. Prompt piped to stdin;
#                       response read from stdout.
#   <KEY>_CHUNK_KB    — max size of one diff chunk sent to the LLM (KB).
# The <KEY> prefix itself must be unique per profile. Reusing a prefix means
# later assignments overwrite earlier ones when bash sources the file.

HAIKU_MODEL_NAME=haiku
HAIKU_LLM_CMD="claude --print --model claude-haiku-4-5"
HAIKU_CHUNK_KB=30

SONNET_LOW_MODEL_NAME=sonnet-low
SONNET_LOW_LLM_CMD="claude --print --model claude-sonnet-4-6 --effort low"
SONNET_LOW_CHUNK_KB=40

OPUS_MAX_MODEL_NAME=opus-max
OPUS_MAX_LLM_CMD="claude --print --model claude-opus-4-6 --effort max"
OPUS_MAX_CHUNK_KB=50

OPUS_47_MAX_MODEL_NAME=opus-4.7-max
OPUS_47_MAX_LLM_CMD="claude --print --model claude-opus-4-7 --effort max"
OPUS_47_MAX_CHUNK_KB=25

CODEX_GPT54_XHIGH_MODEL_NAME=gpt-5.4-xhigh
CODEX_GPT54_XHIGH_LLM_CMD="src/codex-wrap.sh -s read-only --skip-git-repo-check --color never -m gpt-5.4 -c model_reasoning_effort=\"xhigh\""
CODEX_GPT54_XHIGH_CHUNK_KB=25

CODEX_GPT54_MEDIUM_MODEL_NAME=gpt-5.4-medium
CODEX_GPT54_MEDIUM_LLM_CMD="src/codex-wrap.sh -s read-only --skip-git-repo-check --color never -m gpt-5.4 -c model_reasoning_effort=\"medium\""
CODEX_GPT54_MEDIUM_CHUNK_KB=40

CODEX_GPT54_MINI_LOW_MODEL_NAME=gpt-5.4-mini-low
CODEX_GPT54_MINI_LOW_LLM_CMD="src/codex-wrap.sh -s read-only --skip-git-repo-check --color never -m gpt-5.4-mini -c model_reasoning_effort=\"low\""
CODEX_GPT54_MINI_LOW_CHUNK_KB=40

# ─── Local models (ollama) ──────────────────────────────────────────────
# CHUNK_KB for local models is capped by capability, not raw context window.
# Smaller models lose track of details in big inputs even when they fit.
# Treat 15–30 KB as the safe band; raise only after testing on real chunks.

LLAMA_8B_MODEL_NAME=llama-8b
LLAMA_8B_LLM_CMD="ollama run llama3.1:8b"
LLAMA_8B_CHUNK_KB=20

QWEN_32B_MODEL_NAME=qwen-32b
QWEN_32B_LLM_CMD="ollama run qwen2.5:32b"
QWEN_32B_CHUNK_KB=30
