# Copy to .env and fill in. .env itself is gitignored.

# Command to invoke the LLM. Prompt is piped to stdin; output is read from stdout.
# The command must accept arbitrary prompt text on stdin with no further arguments.
LLM_CLI="claude --print --dangerously-skip-permissions --model claude-opus-4-6 --effort max"

# Short name for the model. Used in output paths: diff/models/{LLM_MODEL}/... and
# the final deliverable diff-results/{v1}-{v2}-{LLM_MODEL}.md.
LLM_MODEL=claude-opus-4-6

# Max size per diff chunk sent to the LLM, in KB. Bigger chunks = fewer LLM
# calls but each call does more work. 25 is a reasonable default for Opus-class
# models; reduce if you see truncated outputs, increase for cheaper models.
# NOTE: this is pinned to the model's settings.json on first run — changing it
# later will not re-chunk existing work. To re-chunk, delete the model's
# working directory: rm -rf diff/models/{LLM_MODEL}/{v1}-{v2}/
LLM_CHUNK_SIZE=25
